rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /BinaryBridge/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /User/{userId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    match /Posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uid;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.uid
        || (
          request.resource.data.uid == resource.data.uid
          && (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
            || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['comments'])
          )
        )
      );
    }

    match /Reports/{reportId} {
      allow read: if false;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    match /Likes/{likeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.uid;
      allow update: if false;
    }

    match /Comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid
        && request.resource.data.postId is string
        && request.resource.data.text is string;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.uid;
      allow update: if false;
    }

    match /Follows/{followId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.followerUid
        && request.resource.data.followerUid != request.resource.data.followingUid;
      allow update: if request.auth != null
        && request.auth.uid == request.resource.data.followerUid
        && request.resource.data.followerUid != request.resource.data.followingUid;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.followerUid;
    }

    match /Notifications/{notificationId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.recipientUid;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.actorUid
        && request.resource.data.recipientUid is string
        && request.resource.data.actorUid != request.resource.data.recipientUid
        && request.resource.data.type is string
        && request.resource.data.read == false;
      allow update: if request.auth != null
        && request.auth.uid == resource.data.recipientUid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.actorUid;
    }

    match /PushRequests/{requestId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.senderUid
        && request.resource.data.recipientUid is string
        && request.resource.data.senderUid != request.resource.data.recipientUid
        && request.resource.data.type == 'chat';
      allow read, update, delete: if false;
    }
  }
}
